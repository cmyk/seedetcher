{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Save & Send Patch (macOS Terminal)",
            "type": "shell",
            "command": "osascript",
            "args": [
                "-e",
                "tell application \"Terminal\" to do script \"pbpaste > /tmp/patch.diff && scp /tmp/patch.diff cmyk@ubuntu:/tmp/\""
            ],
            "problemMatcher": []
        },
        {
            "label": "Apply Git Patch (Ubuntu)",
            "type": "shell",
            "command": "ssh -o BatchMode=yes -i ~/.ssh/id_rsa cmyk@ubuntu 'cd ~/seedetcher && git apply --reject --whitespace=fix /tmp/patch.diff'",
            "problemMatcher": []
        },
        {
            "label": "Build and Flash SeedEtcher",
            "type": "shell",
            "command": "./build_and_flash.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Simple Test Task",
            "type": "shell",
            "command": "echo 'Task works!'",
            "problemMatcher": []
        }
    ]
}