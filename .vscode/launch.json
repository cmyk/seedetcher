{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch via nix-shell",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "env": {
                "GOARCH": "arm",
                "GOOS": "linux",
                "GOARM": "6",
                "CGO_ENABLED": "1",
                "CC": "arm-linux-gnueabihf-gcc",
                "CXX": "arm-linux-gnueabihf-g++"
            },
            "preLaunchTask": "nix-shell"
        }
    ]
}